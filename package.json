{
  "name": "starbearer-portfolio",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port=3000 --host=0.0.0.0",
    "dev:open": "vite --port=3000 --host=127.0.0.1 --open",
    "dev:public": "vite --port=3002 --host=0.0.0.0 --strictPort",
    "build": "vite build",
    "preview": "vite preview",
    "preview:open": "vite preview --host 127.0.0.1 --open",
    "share": "ssh -R 80:127.0.0.1:3002 nokey@localhost.run",
    "clean": "node -e \"try{require('node:fs').rmSync('dist',{recursive:true,force:true})}catch(e){process.exit(0)}\"",
    "lint": "tsc --noEmit",
    "check": "npm run lint && npm run build"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "@tailwindcss/vite": "^4.1.14",
    "@vitejs/plugin-react": "^5.0.4",
    "better-sqlite3": "^12.4.1",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.13.1",
    "rehype-raw": "^7.0.0",
    "vite": "^6.2.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "autoprefixer": "^10.4.21",
    "localtunnel": "^2.0.2",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
